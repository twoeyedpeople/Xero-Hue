rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation Blueprints
    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'season', 'hue', 'value', 'chroma', 'reasoning', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.season is string && data.season.size() <= 100 &&
             data.hue is string && data.hue.size() <= 20 &&
             data.value is string && data.value.size() <= 20 &&
             data.chroma is string && data.chroma.size() <= 20 &&
             data.reasoning is string && data.reasoning.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['guestId', 'createdAt']) &&
             data.keys().size() <= 5 &&
             data.guestId is string && data.guestId.size() <= 128 &&
             data.createdAt == request.time;
    }

    // Analyses Collection
    match /analyses/{analysisId} {
      allow create: if isValidId(analysisId) && isValidAnalysis(incoming());
      // For anonymous apps, we allow reading if we have the analysisId
      allow get: if true; 
      // For list, we restrict to the userId provided in the query
      allow list: if request.query.limit <= 20 && resource.data.userId == request.query.userId;
    }

    // Users Collection
    match /users/{userId} {
      allow create: if isValidId(userId) && userId == incoming().guestId && isValidUser(incoming());
      allow get: if isValidId(userId);
      allow update: if isValidId(userId) && 
                      incoming().guestId == existing().guestId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['lastSeason', 'lastUpdatedAt']) &&
                      (incoming().get('lastSeason', '') is string);
    }
  }
}
