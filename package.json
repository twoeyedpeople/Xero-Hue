    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.6.2",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
